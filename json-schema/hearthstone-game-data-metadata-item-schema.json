{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/battle-net/refs/heads/main/json-schema/hearthstone-game-data-metadata-item-schema.json",
  "title": "MetadataItem",
  "description": "A generic metadata item.",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "description": "The unique ID of the metadata item.",
      "example": 1
    },
    "name": {
      "type": "string",
      "description": "The name of the metadata item.",
      "example": "Basic"
    },
    "slug": {
      "type": "string",
      "description": "The slug identifier.",
      "example": "basic"
    }
  }
}